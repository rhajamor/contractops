      "disabling MFA",
      "disable mfa"
    ],
    "max_chars": 620,
    "required_tools": [
      "tool.lookup_security_policy",
      "tool.lookup_user_role"
    ]
  },
  "metadata": {
    "domain": "security",
    "criticality": "critical"
  }
}
